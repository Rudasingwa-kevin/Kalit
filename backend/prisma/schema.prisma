generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  project_manager
  site_engineer
  storekeeper
}

enum UserStatus {
  active
  pending
  inactive
}

enum ProjectStatus {
  on_track
  at_risk
  delayed
  completed
}

enum InvitationStatus {
  pending
  accepted
  expired
}

enum TeamInviteStatus {
  pending
  accepted
  declined
  expired
}

enum ActivityType {
  inventory
  project
  task
  expense
}

enum MilestoneStatus {
  completed
  in_progress
  upcoming
}

model User {
  id        String      @id @default(uuid())
  name      String
  email     String      @unique
  phone     String?
  password  String
  role      UserRole
  status    UserStatus  @default(active)
  company   String?
  joinedAt  DateTime    @default(now())
  invitedBy String?
  avatar    String?

  sentInvitations  Invitation[]  @relation("InvitedBy")
  sentTeamInvites  TeamInvite[]  @relation("TeamInviteOwner")
  receivedTeamInvites TeamInvite[] @relation("TeamInvitee")
  assignedTasks    Task[]        @relation("AssignedTo")
  activities       Activity[]    @relation("ActivityUser")
  createdProjects  Project[]     @relation("CreatedBy")
  managedProjects  Project[]     @relation("ManagedBy")
  projectWorkers   ProjectWorker[]
  teamMemberships  TeamMember[]
  ownedTeams       TeamMember[] @relation("TeamOwner")

  receivedNotifications  Notification[] @relation("NotificationRecipient")
  relatedNotifications   Notification[] @relation("NotificationRelatedUser")
  passwordResetTokens    PasswordResetToken[]

  @@map("users")
}

model TeamMember {
  id          String   @id @default(uuid())
  userId      String
  teamOwnerId String
  role        UserRole
  status      UserStatus @default(active)
  joinedAt    DateTime @default(now())

  user        User  @relation(fields: [userId], references: [id])
  teamOwner   User  @relation("TeamOwner", fields: [teamOwnerId], references: [id])

  @@unique([userId, teamOwnerId])
  @@map("team_members")
}

model Project {
  id              String        @id @default(uuid())
  name            String
  location        String
  status          ProjectStatus @default(on_track)
  progress        Int           @default(0)
  budget          Float
  spent           Float         @default(0)
  startDate       DateTime      @default(now())
  endDate         DateTime
  description     String        @default("")
  materialsUsed   Int           @default(0)
  tasksCompleted  Int           @default(0)
  totalTasks      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdBy       String
  createdByUser   User          @relation("CreatedBy", fields: [createdBy], references: [id])
  managedBy       String?
  managedByUser   User?         @relation("ManagedBy", fields: [managedBy], references: [id])

  tasks          Task[]
  materials      ProjectMaterial[]
  workers        ProjectWorker[]
  budgetLines    BudgetLine[]
  milestones     Milestone[]
  activities     Activity[]

  @@map("projects")
}

model InventoryItem {
  id            String   @id @default(uuid())
  name          String
  category      String
  icon          String   @default("package")
  stock         Float
  maxStock      Float
  unit          String
  value         Float
  supplier      String
  warehouse     String
  status        String   @default("in_stock")
  lastRestocked DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectMaterials ProjectMaterial[]

  @@map("inventory_items")
}

model Invitation {
  id        String           @id @default(uuid())
  name      String
  phone     String
  role      UserRole
  message   String           @default("")
  code      String           @unique
  status    InvitationStatus @default(pending)
  createdAt DateTime         @default(now())
  expiresAt DateTime

  invitedByUser User   @relation("InvitedBy", fields: [invitedBy], references: [id])
  invitedBy     String

  @@map("invitations")
}

model TeamInvite {
  id        String           @id @default(uuid())
  role      UserRole
  message   String           @default("")
  status    TeamInviteStatus @default(pending)
  createdAt DateTime         @default(now())
  expiresAt DateTime

  owner     User   @relation("TeamInviteOwner", fields: [ownerId], references: [id])
  ownerId   String

  invitee   User   @relation("TeamInvitee", fields: [inviteeId], references: [id])
  inviteeId String

  @@unique([ownerId, inviteeId])
  @@map("team_invites")
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  done        Boolean      @default(false)
  date        DateTime     @default(now())
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  assignee   User  @relation("AssignedTo", fields: [assigneeId], references: [id])
  assigneeId String

  @@map("tasks")
}

model ProjectMaterial {
  id       String @id @default(uuid())
  used     Float
  remaining Float
  trend    String @default("stable")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String

  @@unique([projectId, inventoryItemId])
  @@map("project_materials")
}

model ProjectWorker {
  id       String @id @default(uuid())
  hours    Float  @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  user   User @relation(fields: [userId], references: [id])
  userId String

  @@unique([projectId, userId])
  @@map("project_workers")
}

model BudgetLine {
  id        String @id @default(uuid())
  category  String
  allocated Float
  spent     Float  @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@map("budget_lines")
}

model Milestone {
  id       String          @id @default(uuid())
  name     String
  date     DateTime
  status   MilestoneStatus @default(upcoming)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@map("milestones")
}

model Activity {
  id        String       @id @default(uuid())
  action    String
  timestamp DateTime     @default(now())
  type      ActivityType @default(project)

  user   User  @relation("ActivityUser", fields: [userId], references: [id])
  userId String

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?

  @@map("activities")
}

enum NotificationType {
  invite_accepted
  invite_declined
  invite_expired
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id])
  recipientId String

  relatedUserId String?
  relatedUser   User?   @relation("NotificationRelatedUser", fields: [relatedUserId], references: [id])

  @@index([recipientId, read])
  @@map("notifications")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([token])
  @@map("password_reset_tokens")
}
