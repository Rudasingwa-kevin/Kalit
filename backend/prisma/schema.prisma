generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  project_manager
  site_engineer
  storekeeper
}

enum UserStatus {
  active
  pending
  inactive
}

enum ProjectStatus {
  on_track
  at_risk
  delayed
  completed
}

enum InvitationStatus {
  pending
  accepted
  expired
}

enum ActivityType {
  inventory
  project
  task
  expense
}

enum MilestoneStatus {
  completed
  in_progress
  upcoming
}

model User {
  id        String      @id @default(uuid())
  name      String
  email     String      @unique
  phone     String?
  password  String
  role      UserRole
  status    UserStatus  @default(active)
  company   String?
  joinedAt  DateTime    @default(now())
  invitedBy String?
  avatar    String?

  sentInvitations  Invitation[]  @relation("InvitedBy")
  assignedTasks    Task[]        @relation("AssignedTo")
  activities       Activity[]    @relation("ActivityUser")
  createdProjects  Project[]     @relation("CreatedBy")
  managedProjects  Project[]     @relation("ManagedBy")

  @@map("users")
}

model Project {
  id              String        @id @default(uuid())
  name            String
  location        String
  status          ProjectStatus @default(on_track)
  progress        Int           @default(0)
  budget          Float
  spent           Float         @default(0)
  startDate       DateTime      @default(now())
  endDate         DateTime
  description     String        @default("")
  materialsUsed   Int           @default(0)
  tasksCompleted  Int           @default(0)
  totalTasks      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdBy   String
  createdByUser User     @relation("CreatedBy")
  managedBy   String?
  managedByUser User?    @relation("ManagedBy")

  tasks          Task[]
  materials      ProjectMaterial[]
  workers        ProjectWorker[]
  budgetLines    BudgetLine[]
  milestones     Milestone[]
  activities     Activity[]

  @@map("projects")
}

model InventoryItem {
  id            String   @id @default(uuid())
  name          String
  category      String
  icon          String   @default("package")
  stock         Float
  maxStock      Float
  unit          String
  value         Float
  supplier      String
  warehouse     String
  status        String   @default("in_stock")
  lastRestocked DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectMaterials ProjectMaterial[]

  @@map("inventory_items")
}

model Invitation {
  id        String           @id @default(uuid())
  name      String
  phone     String
  role      UserRole
  message   String           @default("")
  code      String           @unique
  status    InvitationStatus @default(pending)
  createdAt DateTime         @default(now())
  expiresAt DateTime

  invitedByUser User @relation("InvitedBy")
  invitedBy     String

  @@map("invitations")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  done        Boolean  @default(false)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  assignee   User  @relation(fields: [assigneeId], references: [id])
  assigneeId String

  @@map("tasks")
}

model ProjectMaterial {
  id       String @id @default(uuid())
  used     Float
  remaining Float
  trend    String @default("stable")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String

  @@unique([projectId, inventoryItemId])
  @@map("project_materials")
}

model ProjectWorker {
  id       String @id @default(uuid())
  hours    Float  @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  user   User @relation(fields: [userId], references: [id])
  userId String

  @@unique([projectId, userId])
  @@map("project_workers")
}

model BudgetLine {
  id        String @id @default(uuid())
  category  String
  allocated Float
  spent     Float  @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@map("budget_lines")
}

model Milestone {
  id       String          @id @default(uuid())
  name     String
  date     DateTime
  status   MilestoneStatus @default(upcoming)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@map("milestones")
}

model Activity {
  id        String       @id @default(uuid())
  action    String
  timestamp DateTime     @default(now())
  type      ActivityType @default(project)

  user   User  @relation("ActivityUser")
  userId String

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?

  @@map("activities")
}
